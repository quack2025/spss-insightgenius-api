# QuantiPro API Configuration
APP_ENV=development
PORT=8000

# API Keys — JSON array of key configs
# Generate a key hash: python -c "import hashlib; print(hashlib.sha256(b'sk_test_your_key_here').hexdigest())"
API_KEYS_JSON='[{"key_hash":"YOUR_SHA256_HASH","name":"Dev Key","plan":"pro","scopes":["process","metadata","convert","crosstab","frequency","parse_ticket"]}]'

# Claude AI (required for ticket parsing + smart labeling)
ANTHROPIC_API_KEY=sk-ant-xxx

# Optional overrides
# MAX_FILE_SIZE_MB=100
# RATE_LIMIT_FREE=10
# RATE_LIMIT_PRO=60
# RATE_LIMIT_BUSINESS=200
